---
// A simple reusable component for your study guides
---
<div class="exam-tip">
  <span class="tip-icon">💡 <strong>UPSC Prelims Tip:</strong></span>
  <div class="tip-content">
    <!-- The <slot /> is where the text you write inside the component will appear -->
    <slot />
  </div>
</div>

<style>
  .exam-tip {
    background-color: #f8f9fa;
    border: 2px solid #e9ecef;
    border-left: 5px solid #cab10a; /* Updated to CivisCraft Gold */
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  }
  
  .tip-icon {
    display: inline-block;
    color: #030370; /* Updated to CivisCraft Blue */
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .tip-content {
    color: #444;
    line-height: 1.6;
  }

  /* This ensures any paragraph passed into the slot doesn't have awkward bottom spacing */
  .tip-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>