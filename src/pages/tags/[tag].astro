---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // Added a safeguard (|| []) just in case a post accidentally has no tags!
  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => (post.data.tags || []).includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout pageTitle={`UPSC Notes: ${tag} | CivisCraft`} description={`All free UPSC study materials related to ${tag}`}>
  <div class="tag-header">
    <h1>📑 Study Guides for: <span class="highlight">#{tag}</span></h1>
    <p>Browse all our free notes and materials for the {tag} syllabus.</p>
  </div>

  <!-- We kept your excellent CSS Grid! -->
  <div class="post-grid">
    {posts.map((post) => (
      <article class="post-card">
        <h2><a href={`/upsc-astro-blog/posts/${post.id}`}>{post.data.title}</a></h2>
        
        <p>{post.data.description}</p>
        
        <a class="read-more" href={`/upsc-astro-blog/posts/${post.id}`}>Read Notes →</a>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .tag-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .highlight {
    color: #030370; /* CivisCraft Blue */
    text-transform: capitalize;
    border-bottom: 3px solid #cab10a; /* CivisCraft Gold */
  }
  
  .post-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .post-card {
    background: #f8f9fa;
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid #cab10a; /* CivisCraft Gold */
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }
  .post-card h2 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .post-card h2 a {
    text-decoration: none;
    color: #030370; /* CivisCraft Blue */
  }
  .post-card h2 a:hover {
    color: #cab10a; /* CivisCraft Gold */
  }
  .read-more {
    display: inline-block;
    margin-top: 1rem;
    color: #cab10a; /* CivisCraft Gold */
    font-weight: bold;
    text-decoration: none;
  }
  .read-more:hover {
    text-decoration: underline;
  }
</style>