---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';

// 1. We define your exact UPSC syllabus structure here!
const syllabus = [
  {
    title: "Prelims",
    subTopics: ["Static", "Current Affairs"]
  },
  {
    title: "General Studies I",
    subTopics: ["Ancient-India", "World History", "Modern History", "Art and Culture", "Geography", "Society"]
  },
  {
    title: "General Studies II",
    subTopics: ["Indian Polity", "Social Justice and Governance", "International Relations"]
  },
  {
    title: "General Studies III",
    subTopics: ["Indian Economy", "Agriculture", "Internal Security", "Environment", "Science and Tech"]
  },
  {
    title: "General Studies IV",
    subTopics: ["Ethics, Integrity, and Aptitude"]
  },
  {
    title: "Essay",
    subTopics: ["Essay Writing"]
  },
  {
    title: "Anthropology Optional",
    subTopics: ["Paper 1", "Paper 2"]
  }
];

// 2. A helper function to turn "Ancient History" into the URL format "ancient-history"
const slugify = (text) => text.toLowerCase().replace(/,/g, '').replace(/\s+/g, '-');
---

<BaseLayout pageTitle="UPSC Notes Hub" description="Free, structured study materials for UPSC Prelims and Mains.">
  <div class="hero-section">
    <h1>🎯 Master the UPSC Syllabus</h1>
    <p>Select a paper and topic below to dive into our free, structured study materials.</p>
  </div>

  <div class="syllabus-container">
    <!-- Astro loops through the syllabus and creates a section for each paper -->
    {syllabus.map((section) => (
      <section class="paper-card">
        <h2>{section.title}</h2>
        
        <div class="sub-cards-grid">
          {section.subTopics.map((topic) => (
            <a href={`/upsc-astro-blog/tags/${slugify(topic)}`} class="sub-card">
              {topic}
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <!-- Keep your waitlist at the bottom of the home page -->
  <EmailSignup />
</BaseLayout>

<style>
  .hero-section {
    text-align: center;
    margin-bottom: 3rem;
  }
  .hero-section h1 {
    color: #0056b3;
    font-size: 2.5rem;
  }
  .syllabus-container {
    display: flex;
    flex-direction: column;
    gap: 2.5rem; /* Space between the main GS papers */
    margin-bottom: 4rem;
  }
  .paper-card {
    background: #f8f9fa;
    padding: 2rem;
    border-radius: 12px;
    border-top: 5px solid #0056b3;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  }
  .paper-card h2 {
    margin-top: 0;
    color: #333;
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #e9ecef;
    padding-bottom: 0.5rem;
  }
  
  /* CSS Grid makes the sub-cards responsive automatically! */
  .sub-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .sub-card {
    background: white;
    padding: 1rem;
    border-radius: 8px;
    text-align: center;
    text-decoration: none;
    color: #0056b3;
    font-weight: bold;
    border: 2px solid #e9ecef;
    transition: all 0.2s ease;
  }
  .sub-card:hover {
    border-color: #ff9900;
    color: white;
    background-color: #ff9900;
    transform: translateY(-3px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }
</style>