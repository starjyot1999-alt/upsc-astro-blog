---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Home - UPSC Prep Hub">
  <h1>Welcome to UPSC Prep Hub</h1>
  <p>Your ultimate free resource for cracking the civil services examination.</p>
  
  <h2>Study Materials</h2>
  
  <div class="subject-grid">
    <!-- Changed from /blog to /tags/polity -->
    <a href="/upsc-astro-blog/tags/polity" class="card">
      <h3>Indian Polity</h3>
      <p>Constitution, Governance, and Social Justice.</p>
    </a>
    
    <!-- Changed from /blog to /tags/history -->
    <a href="/upsc-astro-blog/tags/history" class="card">
      <h3>History</h3>
      <p>Ancient, Medieval, Modern, and Art & Culture.</p>
    </a>
    
    <!-- Changed from /blog to /tags/geography -->
    <a href="/upsc-astro-blog/tags/geography" class="card">
      <h3>Geography</h3>
      <p>Physical, Human, and Economic Geography of India and the World.</p>
    </a>
  </div>
  
  <style>
    .subject-grid {
      display: grid; /* Turns the container into a CSS Grid */
      gap: 1.5rem; /* Explicitly controls the space between the cards */
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); /* The magic responsive grid formula */
      margin-top: 2rem;
    }
    
    .card {
      background-color: #f9f9f9;
      padding: 1.5rem;
      border-radius: 8px;
      text-decoration: none; /* Removes the underline from the links */
      color: #333;
      border: 1px solid #ddd;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    .card:hover {
      transform: translateY(-5px); /* Makes the card float up slightly when hovered */
      box-shadow: 0 6px 12px rgba(0,0,0,0.1);
    }
    
    .card h3 {
      margin-top: 0;
      color: #0056b3;
    }
  </style>
</BaseLayout>