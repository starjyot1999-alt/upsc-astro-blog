---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 1. Fetch all posts from your 'blog' collection instead of using Astro.glob
const allPosts = await getCollection('blog');

// 2. Sort them mathematically by 'pubDate' so the newest posts are at the top
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout pageTitle="UPSC Blog | CivisCraft" description="Read our latest comprehensive UPSC study guides.">
  <main class="blog-container">
    <h1>📚 UPSC Study Guides</h1>
    
    <div class="posts-list">
      {sortedPosts.map(post => (
        <article class="post-card">
          <h2>
            <!-- Ensure this link matches your blog post URL structure! -->
            <a href={`/upsc-astro-blog/posts/${post.id}`}>{post.data.title}</a>
          </h2>
          <div class="meta">
            <!-- Notice we are using .data now instead of .frontmatter! -->
            <span class="author">✍️ By {post.data.author}</span>
            <span class="date">📅 Published: {post.data.pubDate.toISOString().split('T')}</span>
          </div>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .blog-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  h1 {
    color: #030370;
    margin-bottom: 2rem;
  }
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .post-card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    border-left: 5px solid #030370; 
  }
  .post-card h2 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .post-card h2 a {
    color: #030370;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .post-card h2 a:hover {
    color: #cab10a;
  }
  .meta {
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 1rem;
    display: flex;
    gap: 1rem;
  }
</style>