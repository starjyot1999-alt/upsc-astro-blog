---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
---

<BaseLayout pageTitle="About Us" description="Learn more about our mission to help you crack the UPSC exam.">
  <div class="about-container">
    <h1>🎯 About Our UPSC Mission</h1>
    <p>Welcome to your new favorite preparation hub! We know how overwhelming the UPSC syllabus can be, which is why we created this portal.</p>

    <h2>Who We Are</h2>
    <p>We are a team of dedicated educators and past aspirants. Our goal is to provide high-quality, easy-to-read study materials for core subjects like Indian Polity, History, and Geography.</p>

    <h2>Why Choose Us?</h2>
    <ul>
      <li>✅ <strong>Structured Notes:</strong> No more getting lost in heavy textbooks.</li>
      <li>✅ <strong>Exam-Focused:</strong> We only cover what actually matters for Prelims and Mains.</li>
      <li>✅ <strong>Free Access:</strong> High-quality education shouldn't be hidden behind a paywall.</li>
    </ul>

    <!-- Reusing our awesome lead-capture component! -->
    <EmailSignup />
  </div>
</BaseLayout>

<style>
  .about-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
    line-height: 1.6;
  }
  h1 {
    color: #0056b3;
    text-align: center;
    margin-bottom: 2rem;
  }
  h2 {
    color: #333;
    margin-top: 2rem;
    border-bottom: 2px solid #f1f8ff;
    padding-bottom: 0.5rem;
  }
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    background: #f8f9fa;
    margin-bottom: 0.5rem;
    padding: 1rem;
    border-radius: 8px;
    border-left: 4px solid #ff9900;
  }
</style>