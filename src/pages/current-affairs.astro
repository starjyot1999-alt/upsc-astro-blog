---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Fetch all posts from our 'current-affairs' folder
const allUpdates = await getCollection('current-affairs');

// Sort them so the newest dates appear at the top
const sortedUpdates = allUpdates.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout pageTitle="Daily Current Affairs | CivisCraft" description="Daily UPSC news and current affairs.">
  <div class="news-container">
    <h1>📰 Daily Current Affairs</h1>
    <p class="subtitle">Bite-sized daily updates to keep your UPSC preparation on track.</p>

    <div class="updates-list">
      {sortedUpdates.map(update => (
        <div class="news-card">
          <div class="news-header">
            <span class="category">{update.data.category}</span>
            <span class="date">{update.data.date.toISOString().split('T')}</span>
          </div>
          
          <!-- NEW: We wrap the title in an <a> tag pointing to the dynamic URL -->
          <h2>
            <a href={`/upsc-astro-blog/current-affairs/${update.id}`}>
              {update.data.title}
            </a>
          </h2>
          
          <p><em>Click the title to read the full analysis...</em></p>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .news-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  h1 {
    color: #030370; /* CivisCraft Blue */
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .subtitle {
    text-align: center;
    color: #666;
    margin-bottom: 3rem;
  }
  .updates-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .news-card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    border-left: 5px solid #cab10a; 
  }
  .news-header {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: #555;
    margin-bottom: 0.75rem;
  }
  .category {
    background: #e9ecef;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-weight: bold;
    color: #030370;
  }
  .news-card h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.4rem;
  }
  /* NEW: Styling to make the link look great and hover with your brand color */
  .news-card h2 a {
    color: #333;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .news-card h2 a:hover {
    color: #cab10a; /* CivisCraft Gold! */
    text-decoration: underline;
  }
</style>