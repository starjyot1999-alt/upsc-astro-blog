---
import { ClientRouter } from 'astro:transitions';
import AdBanner from '../components/AdBanner.astro';
import Footer from '../components/Footer.astro';
// 1. We keep YOUR excellent default description for SEO
const { pageTitle, description = "CivisCraft: Think, Serve, Lead. Free, high-quality UPSC study materials and notes." } = Astro.props;

// 2. We add the NEW Canonical URL calculator
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width", initial-scale=1.0"/>
    <meta name="generator" content={Astro.generator} />
    
    <!-- Our SEO Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    
    <!-- NEW: Canonical URL to protect your SEO rankings -->
    <link rel="canonical" href={canonicalURL} />

    <!-- NEW: Open Graph tags for beautiful WhatsApp/Twitter/Telegram sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    
    <!-- FIX 1: ClientRouter is safely tucked INSIDE the <head> tags! -->
    <ClientRouter />
  </head>
  <body>
    <!-- FIX 2: Your navigation with transition:persist is untouched! -->
    <nav class="main-nav" transition:persist>
      <!-- The Website Name / Brand -->
      <a href="/upsc-astro-blog/" class="site-title">
        <img src="/upsc-astro-blog/images/logo.png" alt="CivisCraft Logo" class="brand-logo" /> 
        CivisCraft
      </a>
      
      <!-- The Navigation Links -->
      <div class="nav-links">
        <a href="/upsc-astro-blog/">Home</a>
        <a href="/upsc-astro-blog/about">About</a>
        <a href="/upsc-astro-blog/blog">Blog</a>
        <a href="/upsc-astro-blog/tags">Subjects</a>
        <a href="/upsc-astro-blog/current-affairs">Daily Current Affairs</a>
        <a href="/upsc-astro-blog/downloads">Downloads</a>
        <a href="/upsc-astro-blog/contact">Contact</a>
      </div>
    </nav>

    <main style="max-width: 800px; margin: 2rem auto; padding: 0 1rem;">
      <!-- This is where individual page or markdown content is injected -->
      <slot />
    </main>
     <AdBanner />
     <Footer />
  </body>
</html>

<!-- The styling for our new navigation is placed at the very bottom -->
<style>
  /* --- SCOPED STYLES (Only affects this layout file) --- */
  .main-nav {
    background-color: #030370;
    padding: 1rem 2rem;
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
  }
  .site-title {
    color: white;
    font-size: 2.5rem; 
    font-weight: 900;
    text-decoration: none;
    letter-spacing: 1px;
    display: flex;
    gap: 1.5rem; 
    line-height: 1; 
    align-items: center;
  }
  .site-title:hover {
    color: #f8f9fa;
  }
  .brand-logo {
    height: 128px; 
    width: auto;
  }
  .nav-links a {
    color: white;
    margin-left: 1.5rem;
    text-decoration: none;
    font-weight: bold;
    transition: color 0.2s ease;
  }
  .nav-links a:hover {
    color: #cab10a; 
  }
</style>

<style is:global>
  /* --- GLOBAL STYLES (Affects the entire website and Markdown files) --- */
  
  /* 1. Use the modern border-box sizing model for everything */
  html {
    box-sizing: border-box;
  }
  *, *::before, *::after {
    box-sizing: inherit;
  }

  /* 2. Remove default browser margins and prevent horizontal scrolling */
  body {
    margin: 0;
    padding: 0;
    overflow-x: hidden; 
  }

  /* 3. Ensure images, videos, and SVGs never break the screen width */
  img, svg, video {
    max-width: 100%;
    height: auto;
  }
  
  /* 4. Ensure long text or URLs in your study guides wrap to the next line */
  p, h1, h2, h3, a {
    overflow-wrap: break-word;
    word-wrap: break-word;
  }
  /* 5. Prevent Markdown code blocks and tables from stretching the page */
  pre {
    max-width: 100%;
    overflow-x: auto; /* Creates a scrollbar ONLY inside the code box if needed */
  }
  
  table {
    display: block;
    max-width: 100%;
    overflow-x: auto; 
    white-space: nowrap; /* Prevents table columns from squishing too much */
  }
  @media (max-width: 600px) {
    /* 1. Stack the logo and links vertically instead of side-by-side */
    .main-nav {
      flex-direction: column; 
      gap: 1rem;
      padding: 1rem;
    }
    
    /* 2. Shrink the giant title slightly for small screens */
    .site-title {
      font-size: 1.8rem; 
    }

    /* 3. Turn the links container into a wrapping flexbox */
    .nav-links {
      display: flex;
      flex-wrap: wrap; /* This is the magic that stops the stretching! */
      justify-content: center;
      gap: 1rem;
    }

    /* 4. Remove the rigid left margin from desktop */
    .nav-links a {
      margin-left: 0; 
    }
  }
</style>