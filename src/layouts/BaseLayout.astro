---
// We accept the pageTitle, and optionally a description for SEO
const { pageTitle, description = "High-quality, free UPSC study materials and notes." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Our SEO Tags -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <!-- Main Navigation Menu -->
    <nav style="background-color: #0056b3; padding: 1rem; text-align: center;">
  <a href="/upsc-astro-blog/" style="color: white; margin: 0 1rem; text-decoration: none; font-weight: bold;">Home</a>
  <a href="/upsc-astro-blog/about" style="color: white; margin: 0 1rem; text-decoration: none; font-weight: bold;">About</a>
  <a href="/upsc-astro-blog/blog" style="color: white; margin: 0 1rem; text-decoration: none; font-weight: bold;">Blog</a>
  <!-- Our new Categories link! -->
  <a href="/upsc-astro-blog/tags" style="color: white; margin: 0 1rem; text-decoration: none; font-weight: bold;">Subjects</a>
  <a href="/upsc-astro-blog/downloads" style="color: white; margin: 0 1rem; text-decoration: none; font-weight: bold;">Downloads</a>
  <a href="/upsc-astro-blog/contact" style="color: white; margin: 0 1rem; text-decoration: none; font-weight: bold;">Contact</a>
</nav>

    <main style="max-width: 800px; margin: 2rem auto; padding: 0 1rem;">
      <!-- This is where individual page or markdown content is injected -->
      <slot />
    </main>
  </body>
</html>