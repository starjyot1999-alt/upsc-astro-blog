---
import BaseLayout from './BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import AdBanner from '../components/AdBanner.astro';

// 1. Astro automatically passes a "headings" array alongside your frontmatter!
const { frontmatter, headings } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title} description={frontmatter.description}>
  <div class="post-header">
    <h1>{frontmatter.title}</h1>
    <p><em>{frontmatter.description}</em></p>
  </div>

  <!-- 2. Automatically generate the Table of Contents if headings exist -->
  {headings && headings.length > 0 && (
    <nav class="toc">
      <h2>📑 Table of Contents</h2>
      <ul>
        {headings.map((heading) => (
          <li class={`depth-${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <!-- 3. The actual post content renders here! -->
  <div class="post-content">
    <slot />
  </div>
  
  <AdBanner />
  <EmailSignup />
</BaseLayout>

<style>
  /* Global smooth scrolling so the page glides to the section! */
  :global(html) {
    scroll-behavior: smooth;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-header h1 {
    color: #333;
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  /* Table of Contents Styling */
  .toc {
    background-color: #f8f9fa;
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
    border-left: 4px solid #0056b3;
  }
  
  .toc h2 {
    margin-top: 0;
    font-size: 1.2rem;
    color: #333;
    margin-bottom: 1rem;
  }
  
  .toc ul {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }
  
  .toc li {
    margin-bottom: 0.5rem;
  }

  /* Indent H3 and H4 headings to create a visual hierarchy */
  .toc .depth-3 { padding-left: 1.5rem; }
  .toc .depth-4 { padding-left: 3rem; }
  
  .toc a {
    text-decoration: none;
    color: #0056b3;
    transition: color 0.2s ease;
  }
  
  .toc a:hover {
    color: #ff9900;
    text-decoration: underline;
  }

  /* Basic styling for the markdown content */
  .post-content {
    line-height: 1.8;
    font-size: 1.1rem;
    color: #444;
  }
</style>